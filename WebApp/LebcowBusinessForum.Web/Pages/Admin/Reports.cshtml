@page
@model LebcowBusinessForum.Web.Pages.Admin.ReportsModel
@{
    ViewData["Title"] = "Admin — Reports";
}

<div class="container admin-page admin-shell py-4">
    <header class="admin-header">
        <div>
            <h1 class="page-title">Reports &amp; Analytics</h1>
            <p class="admin-subtitle">A quick operational snapshot of platform growth, quality, and category distribution.</p>
        </div>
        <div class="admin-header__actions">
            <a href="/Admin" class="btn btn--outline btn--sm">Back to Admin</a>
        </div>
    </header>

    <section class="admin-kpi-grid admin-kpi-grid--dense">
        <article class="admin-kpi-card"><span class="admin-kpi-card__label">Users</span><strong class="admin-kpi-card__value">@Model.TotalUsers</strong></article>
        <article class="admin-kpi-card"><span class="admin-kpi-card__label">Businesses</span><strong class="admin-kpi-card__value">@Model.TotalBusinesses</strong></article>
        <article class="admin-kpi-card"><span class="admin-kpi-card__label">Approved</span><strong class="admin-kpi-card__value">@Model.ApprovedBusinesses</strong></article>
        <article class="admin-kpi-card"><span class="admin-kpi-card__label">Pending</span><strong class="admin-kpi-card__value">@Model.PendingBusinesses</strong></article>
        <article class="admin-kpi-card"><span class="admin-kpi-card__label">Rejected</span><strong class="admin-kpi-card__value">@Model.RejectedBusinesses</strong></article>
        <article class="admin-kpi-card"><span class="admin-kpi-card__label">Reviews</span><strong class="admin-kpi-card__value">@Model.TotalReviews</strong></article>
        <article class="admin-kpi-card"><span class="admin-kpi-card__label">Events</span><strong class="admin-kpi-card__value">@Model.TotalEvents</strong></article>
        <article class="admin-kpi-card"><span class="admin-kpi-card__label">Listings</span><strong class="admin-kpi-card__value">@Model.TotalListings</strong></article>
    </section>

    <section class="admin-report-grid">
        <article class="admin-panel">
            <div class="admin-panel__header">
                <h2>Businesses by Region</h2>
                <p>Sorted by count (descending).</p>
            </div>
            @if (Model.ByRegion.Count == 0)
            {
                <div class="admin-empty-state">No data available.</div>
            }
            else
            {
                <div class="admin-table-wrap">
                    <table class="admin-data-table">
                        <thead>
                            <tr>
                                <th>Region</th>
                                <th>Count</th>
                                <th>Percentage</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var (region, count) in Model.ByRegion)
                            {
                                var percentage = Model.TotalBusinesses == 0 ? 0 : (count * 100.0) / Model.TotalBusinesses;
                                <tr>
                                    <td data-label="Region">@region</td>
                                    <td data-label="Count"><span class="badge badge--free">@count</span></td>
                                    <td data-label="Percentage">@percentage.ToString("0.0")%</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </article>

        <article class="admin-panel">
            <div class="admin-panel__header">
                <h2>Businesses by Category</h2>
                <p>Most active categories at a glance.</p>
            </div>
            @if (Model.ByCategory.Count == 0)
            {
                <div class="admin-empty-state">No data available.</div>
            }
            else
            {
                <div class="admin-table-wrap">
                    <table class="admin-data-table">
                        <thead>
                            <tr>
                                <th>Category</th>
                                <th>Count</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var (category, count) in Model.ByCategory)
                            {
                                <tr>
                                    <td data-label="Category">@category</td>
                                    <td data-label="Count"><span class="badge badge--free">@count</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </article>

        <article class="admin-panel admin-panel--span">
            <div class="admin-panel__header">
                <h2>Listing Tier Breakdown</h2>
                <p>Distribution across free, premium, and featured plans.</p>
            </div>
            <div class="admin-tier-grid">
                <div class="admin-tier-card">
                    <span>Free</span>
                    <strong>@Model.FreeListings</strong>
                </div>
                <div class="admin-tier-card">
                    <span>Premium</span>
                    <strong>@Model.PremiumListings</strong>
                </div>
                <div class="admin-tier-card">
                    <span>Featured</span>
                    <strong>@Model.FeaturedListings</strong>
                </div>
            </div>
        </article>
    </section>

    <p class="admin-generated-at">Report generated: @DateTime.UtcNow.ToString("dd MMM yyyy HH:mm") UTC</p>
</div>
