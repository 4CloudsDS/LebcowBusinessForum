@page
@model LebcowBusinessForum.Web.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container admin-page">
    <h1 class="page-title">Admin Dashboard</h1>

    <div class="admin-stats">
        <div class="stat-card">
            <span class="stat-card__value">@Model.PendingListings</span>
            <span class="stat-card__label">Pending Listings</span>
        </div>
        <div class="stat-card">
            <span class="stat-card__value">@Model.TotalBusinesses</span>
            <span class="stat-card__label">Total Businesses</span>
        </div>
        <div class="stat-card">
            <span class="stat-card__value">@Model.TotalUsers</span>
            <span class="stat-card__label">Registered Users</span>
        </div>
        <div class="stat-card">
            <span class="stat-card__value">@Model.PendingReviews</span>
            <span class="stat-card__label">Reviews to Moderate</span>
        </div>
    </div>

    <nav class="admin-nav" aria-label="Admin sections">
        <ul>
            <li><a href="/Admin/Listings" class="btn btn--outline">Manage Listings</a></li>
            <li><a href="/Admin/Categories" class="btn btn--outline">Manage Categories</a></li>
            <li><a href="/Admin/Reviews" class="btn btn--outline">Moderate Reviews</a></li>
            <li><a href="/Admin/Users" class="btn btn--outline">Manage Users</a></li>
            <li><a href="/Admin/Reports" class="btn btn--outline">Reports</a></li>
        </ul>
    </nav>
</div>
