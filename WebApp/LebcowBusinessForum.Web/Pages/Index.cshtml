@page
@model LebcowBusinessForum.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Home";
}

<section class="hero" aria-labelledby="hero-heading">
    <div class="hero__inner">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <p class="hero__subtitle" style="margin-bottom:0.25rem;">Welcome back: @(Model.WelcomeName ?? "Member")</p>
        }
        <h1 id="hero-heading" class="hero__title">
            Find Trusted South African Businesses
        </h1>
        <p class="hero__subtitle">
            Browse thousands of verified local businesses, read reviews, and connect with your community.
        </p>
        <form method="get" action="/Browse" class="hero__search" role="search" aria-label="Business search">
            <label for="hero-search-input" class="sr-only">Search businesses</label>
            <input id="hero-search-input"
                   type="search"
                   name="q"
                   placeholder="Restaurant, lawyer, plumber..."
                   class="search-input"
                   autocomplete="off"
                   aria-label="Search term" />
            <label for="hero-location-input" class="sr-only">Location</label>
            <input id="hero-location-input"
                   type="text"
                   name="location"
                   placeholder="City or province"
                   class="search-input search-input--location"
                   aria-label="Location" />
            <button type="submit" class="btn btn--primary">Search</button>
        </form>
    </div>
</section>

<div class="trust-bar" aria-label="Trust signals">
    <ul class="trust-bar__list">
        <li class="trust-bar__item"><span class="trust-bar__icon" aria-hidden="true">&#10003;</span> Verified businesses</li>
        <li class="trust-bar__item"><span class="trust-bar__icon" aria-hidden="true">&#9733;</span> Trusted community reviews</li>
        <li class="trust-bar__item"><span class="trust-bar__icon" aria-hidden="true">&#128274;</span> Free to browse &mdash; no account needed</li>
        <li class="trust-bar__item"><span class="trust-bar__icon" aria-hidden="true">&#127481;&#127487;</span> South Africa&rsquo;s local business directory</li>
    </ul>
</div>
    <div class="container">
        <h2 id="categories-heading" class="section-title">Browse by Category</h2>
        <ul class="categories-grid" aria-label="Business categories">
            @foreach (var cat in Model.FeaturedCategories)
            {
                <li>
                    <a href="/Browse?category=@cat.CategoryId" class="category-tile">
                        <span class="category-tile__icon" aria-hidden="true">@GetCategoryIcon(cat.Name)</span>
                        <span class="category-tile__name">@cat.Name</span>
                    </a>
                </li>
            }
        </ul>
    </div>
</section>

@functions {
    static string GetCategoryIcon(string? name)
    {
        var n = (name ?? string.Empty).ToLowerInvariant();

        if (n.Contains("restaurant") || n.Contains("food") || n.Contains("eat")) return "\uD83C\uDF7D\uFE0F";
        if (n.Contains("health") || n.Contains("medical") || n.Contains("clinic")) return "\uD83C\uDFE5";
        if (n.Contains("legal") || n.Contains("law") || n.Contains("attorney")) return "\u2696\uFE0F";
        if (n.Contains("retail") || n.Contains("shop") || n.Contains("store")) return "\uD83D\uDECD\uFE0F";
        if (n.Contains("tech") || n.Contains("it") || n.Contains("digital")) return "\uD83D\uDCBB";
        if (n.Contains("education") || n.Contains("school") || n.Contains("tutoring")) return "\uD83C\uDF93";
        if (n.Contains("transport") || n.Contains("logistic") || n.Contains("delivery")) return "\uD83D\uDE9A";
        if (n.Contains("beauty") || n.Contains("salon") || n.Contains("spa")) return "\u2728";
        if (n.Contains("construction") || n.Contains("build") || n.Contains("plumb")) return "\uD83D\uDD28";
        if (n.Contains("finance") || n.Contains("bank") || n.Contains("accounting")) return "\uD83D\uDCB0";
        return "\uD83C\uDFEA";
    }
}

<section class="featured-section" aria-labelledby="featured-heading">
    <div class="container">
        <h2 id="featured-heading" class="section-title">Featured Businesses</h2>
        <div class="business-grid">
            @foreach (var biz in Model.FeaturedBusinesses)
            {
                <partial name="_BusinessCard" model="biz" />
            }
        </div>
    </div>
</section>

<section class="events-section" aria-labelledby="events-heading">
    <div class="container">
        <h2 id="events-heading" class="section-title">Upcoming Events</h2>
        <ul class="events-list">
            @foreach (var ev in Model.UpcomingEvents)
            {
                <li class="event-item">
                    <time datetime="@ev.Date.ToString("yyyy-MM-dd")" class="event-item__date">
                        @ev.Date.ToString("d MMM yyyy")
                    </time>
                    <div class="event-item__details">
                        <h3 class="event-item__title">@ev.Title</h3>
                        <p class="event-item__location">@ev.Location</p>
                    </div>
                    <a href="/Events/@ev.EventId" class="btn btn--ghost btn--sm">View</a>
                </li>
            }
        </ul>
        <a href="/Events" class="link-more">View all events &rarr;</a>
    </div>
</section>

<section class="cta-section" aria-labelledby="cta-heading">
    <div class="container">
        <h2 id="cta-heading" class="cta__title">Own a Business?</h2>
        <p class="cta__body">List your business for free and reach thousands of customers across South Africa.</p>
        <a href="/Account/Register" class="btn btn--primary btn--lg">Get Listed</a>
    </div>
</section>
