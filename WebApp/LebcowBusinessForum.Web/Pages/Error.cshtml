@page "/Error"
@model LebcowBusinessForum.Web.Pages.ErrorModel
@{
    ViewData["Title"] = "Error";
    ViewData["Description"] = "An unexpected error occurred.";
}

<div class="error-page" role="main" aria-labelledby="error-heading">
    <p class="error-page__code" aria-hidden="true">500</p>
    <h1 id="error-heading" class="error-page__title">Something went wrong</h1>
    <p class="error-page__body">
        We're sorry — an unexpected error occurred. Our team has been notified.
        Please try again in a moment or return home.
    </p>
    <div class="flex gap-md" style="display:flex;gap:1rem;flex-wrap:wrap;justify-content:center;">
        <a href="/" class="btn btn--primary">Return Home</a>
        <a href="/Contact" class="btn btn--outline">Contact Support</a>
    </div>
    @if (Model.ShowRequestId)
    {
        <p class="mt-4 text-muted" style="margin-top:2rem;color:var(--color-text-muted);font-size:.8rem;">
            Request ID: <code>@Model.RequestId</code>
        </p>
    }
</div>
