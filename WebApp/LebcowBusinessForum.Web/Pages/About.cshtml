@page
@{
    ViewData["Title"] = "About Us";
    ViewData["Description"] = "Learn how LebcowBusiness Forum connects South African consumers with trusted local businesses.";
}

<section class="hero" aria-labelledby="about-hero-title">
    <div class="hero__inner">
        <p class="hero__eyebrow">Our Story</p>
        <h1 id="about-hero-title" class="hero__title">Built to help South African local business grow</h1>
        <p class="hero__subtitle">We connect people with trusted businesses, highlight local events, and keep community feedback transparent and useful.</p>
        <div class="hero__actions">
            <a href="/Browse" class="btn btn--accent">Browse Businesses</a>
            <a href="/Account/Register" class="btn btn--outline">Join for Free</a>
        </div>
    </div>
</section>

<div class="content-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
        <ol>
            <li><a href="/">Home</a></li>
            <li aria-current="page">About</li>
        </ol>
    </nav>

    <div class="content-layout">
        <main>
            <section class="content-section" aria-labelledby="who-we-are">
                <h2 id="who-we-are" class="content-section__title">Who We Are</h2>
                <p>
                    LebcowBusiness Forum is a South African online directory and community platform dedicated to connecting
                    local businesses with customers across the country.
                </p>
                <p>
                    Founded to empower small and medium enterprises, we provide a space where businesses can list their
                    services, connect with customers, and grow their presence in the local economy.
                </p>
            </section>

            <section class="content-section" aria-labelledby="our-mission">
                <h2 id="our-mission" class="content-section__title">Our Mission</h2>
                <p>
                    Our mission is to make it easier for South African consumers to discover and support local businesses,
                    while giving business owners the tools they need to reach their audience and build their brand online.
                </p>
            </section>

            <section class="content-section" aria-labelledby="what-we-offer">
                <h2 id="what-we-offer" class="content-section__title">What We Offer</h2>
                <ul class="content-feature-list" role="list">
                    <li>
                        <span class="content-feature-list__icon" aria-hidden="true">🏢</span>
                        <div><strong>Business Directory</strong> — Browse verified local businesses across South Africa.</div>
                    </li>
                    <li>
                        <span class="content-feature-list__icon" aria-hidden="true">⭐</span>
                        <div><strong>Reviews &amp; Ratings</strong> — Community feedback to help you make confident decisions.</div>
                    </li>
                    <li>
                        <span class="content-feature-list__icon" aria-hidden="true">📅</span>
                        <div><strong>Events</strong> — Discover business networking events and local meetups.</div>
                    </li>
                    <li>
                        <span class="content-feature-list__icon" aria-hidden="true">🚀</span>
                        <div><strong>Premium Listings</strong> — Increase visibility with featured placement options.</div>
                    </li>
                    <li>
                        <span class="content-feature-list__icon" aria-hidden="true">💬</span>
                        <div><strong>Community Forum</strong> — Share ideas and collaborate with business owners and customers.</div>
                    </li>
                </ul>
            </section>

            <section class="content-section" aria-labelledby="get-involved">
                <h2 id="get-involved" class="content-section__title">Get Involved</h2>
                <p>
                    Whether you are a business owner looking to grow your customer base, or a customer searching for
                    quality local services, LebcowBusiness Forum is your community.
                </p>
                <div style="display:flex;gap:var(--space-sm);flex-wrap:wrap;margin-top:var(--space-md);">
                    <a href="/Account/Register" class="btn btn--primary">Join for Free</a>
                    <a href="/Browse" class="btn btn--outline">Browse Businesses</a>
                    <a href="/Contact" class="btn btn--outline">Contact Us</a>
                </div>
            </section>
        </main>

        <aside>
            <div class="content-sidebar-card">
                <h2 class="content-sidebar-card__title">Quick Facts</h2>
                <div class="admin-kpi-grid admin-kpi-grid--dense" role="list">
                    <article class="admin-kpi-card" role="listitem">
                        <span class="admin-kpi-card__label">Coverage</span>
                        <strong class="admin-kpi-card__value">9 Provinces</strong>
                    </article>
                    <article class="admin-kpi-card" role="listitem">
                        <span class="admin-kpi-card__label">Focus</span>
                        <strong class="admin-kpi-card__value">SME Growth</strong>
                    </article>
                    <article class="admin-kpi-card" role="listitem">
                        <span class="admin-kpi-card__label">Model</span>
                        <strong class="admin-kpi-card__value">Community Led</strong>
                    </article>
                    <article class="admin-kpi-card" role="listitem">
                        <span class="admin-kpi-card__label">Listing</span>
                        <strong class="admin-kpi-card__value">Free Entry</strong>
                    </article>
                </div>
            </div>

            <div class="content-sidebar-card">
                <h2 class="content-sidebar-card__title">Need help?</h2>
                <p style="color:var(--color-text-muted);font-size:.9rem;margin-bottom:var(--space-md);line-height:1.6;">
                    Have questions or feedback? Reach out and we will guide you.
                </p>
                <a href="/Contact" class="btn btn--outline" style="width:100%;text-align:center;">Get in Touch</a>
            </div>

            <div class="content-sidebar-card" style="background:var(--color-primary);border-color:var(--color-primary-dark);">
                <h2 class="content-sidebar-card__title" style="color:#fff;">List Your Business</h2>
                <p style="color:rgba(255,255,255,.85);font-size:.9rem;margin-bottom:var(--space-md);line-height:1.6;">
                    Get discovered by thousands of local customers. It's free to start.
                </p>
                <a href="/Account/Register" class="btn btn--accent" style="width:100%;text-align:center;">Get Started</a>
            </div>
        </aside>
    </div>
</div>
