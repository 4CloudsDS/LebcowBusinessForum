@page "{id:guid}"
@model LebcowBusinessForum.Web.Pages.BusinessOwner.EditModel
@{
    ViewData["Title"] = "Edit Business";
}

<div class="container py-5" style="max-width:700px;">
    <h1 class="mb-2">Edit Business</h1>
    @if (Model.Business is not null)
    {
        <p class="text-muted mb-4">
            Editing <strong>@Model.Business.Name</strong>.
            @if (!User.IsInRole("Admin"))
            {
                <span class="text-warning">Saving will reset the listing to <strong>pending</strong> until an admin approves the changes.</span>
            }
        </p>
    }

    <form method="post">
        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="Input.Name" class="form-label"></label>
            <input asp-for="Input.Name" class="form-control" />
            <span asp-validation-for="Input.Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Input.CategoryId" class="form-label"></label>
            <select asp-for="Input.CategoryId" class="form-select"
                    asp-items="@(new SelectList(Model.Categories, "CategoryId", "Name"))">
                <option value="">— Select category —</option>
            </select>
            <span asp-validation-for="Input.CategoryId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Input.Description" class="form-label"></label>
            <textarea asp-for="Input.Description" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Input.Description" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Input.Address" class="form-label"></label>
            <input asp-for="Input.Address" class="form-control" />
            <span asp-validation-for="Input.Address" class="text-danger"></span>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Input.Phone" class="form-label"></label>
                <input asp-for="Input.Phone" class="form-control" />
                <span asp-validation-for="Input.Phone" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Input.Email" class="form-label"></label>
                <input asp-for="Input.Email" class="form-control" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
        </div>

        <div class="mb-4">
            <label asp-for="Input.Website" class="form-label"></label>
            <input asp-for="Input.Website" class="form-control" placeholder="https://..." />
            <span asp-validation-for="Input.Website" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a asp-page="/Account/Dashboard" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>

    @if (Model.Business?.Status == "delisted")
    {
        <div class="alert alert-info mt-4" role="alert">
            <strong>This business is currently delisted.</strong>
            Update the details above and save to resubmit it for admin approval.
        </div>
    }

    @if (Model.Business is not null)
    {
        <hr class="mt-4" />
        <div class="border border-danger rounded p-3 mt-2">
            <h5 class="text-danger">Danger Zone</h5>

            @if (Model.Business.Status == "approved" && !User.IsInRole("Admin"))
            {
                <p class="mb-2 small text-muted">Remove this business from the public directory. You can edit and resubmit it for approval afterwards.</p>
                <form method="post" asp-page-handler="Delist" asp-route-id="@Model.Business.BusinessId"
                      onsubmit="return confirm('Delist this business? It will be removed from the public directory but you can resubmit it for approval.')"
                      class="d-inline me-2">
                    <button type="submit" class="btn btn-warning btn-sm">Delist Business</button>
                </form>
            }

            <p class="mb-2 small text-muted @(Model.Business.Status == "approved" && !User.IsInRole("Admin") ? "mt-3" : "")">Permanently delete this business and all its data. This cannot be undone.</p>
            <form method="post" asp-page-handler="DeleteBusiness" asp-route-id="@Model.Business.BusinessId"
                  onsubmit="return confirm('Permanently delete this business? All listings, reviews, and data will be removed. This cannot be undone.')">
                <button type="submit" class="btn btn-danger btn-sm">Permanently Delete</button>
            </form>
        </div>
    }
</div>
