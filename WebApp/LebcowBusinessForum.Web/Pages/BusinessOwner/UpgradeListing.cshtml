@page "{businessId:guid}"
@model LebcowBusinessForum.Web.Pages.BusinessOwner.UpgradeListingModel
@{
    ViewData["Title"] = "Upgrade Your Listing";
}

<div class="container py-5" style="max-width:600px;">
    <h1 class="mb-4">Upgrade Listing</h1>
    @if (Model.Business is not null)
    {
        <p class="text-muted mb-4">Upgrade <strong>@Model.Business.Name</strong> for increased visibility.</p>
    }

    <form method="post">
        <div asp-validation-summary="All" class="text-danger mb-3"></div>
        <div class="mb-4">
            <div class="form-check mb-2">
                <input class="form-check-input" type="radio" asp-for="Tier" value="premium" id="tierPremium" checked />
                <label class="form-check-label" for="tierPremium">
                    <strong>Premium</strong> — R299/month — highlighted listing with priority placement
                </label>
            </div>
            <div class="form-check">
                <input class="form-check-input" type="radio" asp-for="Tier" value="featured" id="tierFeatured" />
                <label class="form-check-label" for="tierFeatured">
                    <strong>Featured</strong> — R599/month — homepage spotlight + premium benefits
                </label>
            </div>
        </div>

        <div class="alert alert-info small">
            Payment integration (PayFast / Stripe) is being configured.
            Submitting this form registers your upgrade intent. You will be contacted to complete payment.
        </div>

        <button type="submit" class="btn btn-primary">Request Upgrade</button>
        <a asp-page="/Account/Dashboard" class="btn btn-outline-secondary ms-2">Cancel</a>
    </form>
</div>
