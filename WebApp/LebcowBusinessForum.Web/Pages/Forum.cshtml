@page
@model LebcowBusinessForum.Web.Pages.ForumModel
@{
    ViewData["Title"] = "Community Forum";
}

<div class="container forum-page">
    <div class="forum-page__head">
        <h1 class="page-title">Community Forum</h1>
        <form method="get" class="forum-tools" aria-label="Forum sorting options">
            <input type="hidden" name="pageNumber" value="@Model.PageNumber" />
            <label class="forum-tools__toggle">
                <input type="checkbox" name="prioritizeOfficial" value="true" @(Model.PrioritizeOfficial ? "checked" : null) onchange="this.form.submit()" />
                Pin official updates first
            </label>
        </form>
    </div>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <section class="forum-composer" aria-labelledby="new-post-heading">
            <h2 id="new-post-heading" class="auth-card__title">New Post</h2>
            <form method="post">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="alert alert--danger" role="alert"></div>
                }
                <div class="form-group">
                    <label class="form-label" asp-for="NewPostTitle">Title</label>
                    <input asp-for="NewPostTitle" class="form-control" maxlength="200" required />
                    <span asp-validation-for="NewPostTitle" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="NewPostBody">Message</label>
                    <textarea asp-for="NewPostBody" class="form-control" rows="4" required></textarea>
                    <span asp-validation-for="NewPostBody" class="field-error"></span>
                </div>
                <button type="submit" class="btn btn--primary">Post</button>
            </form>
        </section>
    }
    else
    {
        <div style="margin-bottom:var(--space-xl);">
            <button class="btn btn--primary" disabled
                    aria-disabled="true"
                    title="Sign in to post in the forum"
                    style="cursor:not-allowed;opacity:.55;">
                New Post
            </button>
            <p class="results-count" style="margin-top:var(--space-sm);">
                <a href="/Account/Login">Sign in</a> to join the discussion.
            </p>
        </div>
    }

    <div id="forum-posts">
        @foreach (var post in Model.Posts)
        {
            var isAdminPost = Model.AdminAuthorIds.Contains(post.AuthorId);
            var currentUserId = Model.CurrentUserId;
            <article class="forum-post-card @(isAdminPost ? "forum-post-card--admin" : string.Empty) @(post.IsFlagged ? "forum-post-card--flagged" : string.Empty)">
                <header class="forum-post-card__meta">
                    <span class="business-card__logo-placeholder forum-post-card__avatar" aria-hidden="true">
                        @(post.Author?.FullName?[0] ?? '?')
                    </span>
                    <div>
                        <div class="forum-post-card__author-line">
                            <strong>@(post.Author?.FullName ?? "Unknown")</strong>
                            @if (isAdminPost)
                            {
                                <span class="forum-official-badge" title="Official update by administrator">
                                    <span aria-hidden="true">📌</span>
                                    Official update
                                </span>
                            }
                            @if (post.IsFlagged)
                            {
                                <span class="forum-flag-badge" title="This post has been flagged">⚑ Flagged</span>
                            }
                        </div>
                        <time class="review-item__date" datetime="@post.CreatedAt.ToString("yyyy-MM-dd")">
                            @post.CreatedAt.ToString("d MMM yyyy")
                        </time>
                    </div>
                </header>
                <h3 class="forum-post-card__title">@post.Title</h3>
                <p class="forum-post-card__body">@post.Body</p>

                <div class="forum-post-card__actions">
                    @if (User.Identity?.IsAuthenticated == true && post.AuthorId.ToString() != currentUserId)
                    {
                        @if (!post.IsFlagged)
                        {
                            <form method="post" asp-page-handler="Flag" style="display:inline">
                                <input type="hidden" name="postId" value="@post.PostId" />
                                <button type="submit" class="btn btn--ghost btn--xs" title="Flag this post as inappropriate">⚑ Flag</button>
                            </form>
                        }
                    }
                    @if (User.IsInRole("Admin"))
                    {
                        @if (post.IsFlagged)
                        {
                            <form method="post" asp-page-handler="Unflag" style="display:inline">
                                <input type="hidden" name="postId" value="@post.PostId" />
                                <button type="submit" class="btn btn--outline btn--xs">Clear Flag</button>
                            </form>
                        }
                        <form method="post" asp-page-handler="DeletePost" style="display:inline"
                              onsubmit="return confirm('Delete this post and all its replies?')">
                            <input type="hidden" name="postId" value="@post.PostId" />
                            <button type="submit" class="btn btn--danger btn--xs">Delete</button>
                        </form>
                    }
                </div>

                @if (post.Replies.Any())
                {
                    <div class="forum-replies">
                        @foreach (var reply in post.Replies)
                        {
                            <div class="forum-reply">
                                <div class="forum-reply__meta">
                                    <span class="business-card__logo-placeholder forum-reply__avatar" aria-hidden="true">
                                        @(reply.Author?.FullName?[0] ?? '?')
                                    </span>
                                    <strong class="forum-reply__author">@(reply.Author?.FullName ?? "Unknown")</strong>
                                    <time class="forum-reply__date" datetime="@reply.CreatedAt.ToString("yyyy-MM-dd")">
                                        @reply.CreatedAt.ToString("d MMM yyyy")
                                    </time>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <form method="post" asp-page-handler="DeleteReply" style="display:inline;margin-left:auto">
                                            <input type="hidden" name="replyId" value="@reply.ReplyId" />
                                            <button type="submit" class="btn btn--danger btn--xs" title="Delete reply"
                                                    onclick="return confirm('Delete this reply?')">✕</button>
                                        </form>
                                    }
                                </div>
                                <p class="forum-reply__body">@reply.Body</p>
                            </div>
                        }
                    </div>
                }

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <details class="forum-reply-composer">
                        <summary class="btn btn--ghost btn--xs forum-reply-toggle">Reply</summary>
                        <form method="post" asp-page-handler="Reply" class="forum-reply-form">
                            <input type="hidden" name="postId" value="@post.PostId" />
                            <div class="form-group" style="margin-top:var(--space-sm)">
                                <textarea name="ReplyBody" class="form-control forum-reply-input" rows="3"
                                          placeholder="Write a reply…" maxlength="5000" required></textarea>
                            </div>
                            <button type="submit" class="btn btn--primary btn--sm">Post Reply</button>
                        </form>
                    </details>
                }
            </article>
        }

        @if (!Model.Posts.Any())
        {
            <p class="no-results">No forum posts yet. Be the first to start a discussion!</p>
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="pager" aria-label="Forum pagination" style="margin-top:var(--space-lg);">
            <ul class="pager__list">
                @if (Model.PageNumber > 1)
                {
                    <li><a href="?pageNumber=@(Model.PageNumber - 1)&prioritizeOfficial=@Model.PrioritizeOfficial" class="btn btn--ghost btn--sm" aria-label="Previous page">← Prev</a></li>
                }
                @for (int p = 1; p <= Model.TotalPages; p++)
                {
                    <li><a href="?pageNumber=@p&prioritizeOfficial=@Model.PrioritizeOfficial" class="btn btn--sm @(p == Model.PageNumber ? "btn--primary" : "btn--ghost")" aria-current="@(p == Model.PageNumber ? "page" : null)">@p</a></li>
                }
                @if (Model.PageNumber < Model.TotalPages)
                {
                    <li><a href="?pageNumber=@(Model.PageNumber + 1)&prioritizeOfficial=@Model.PrioritizeOfficial" class="btn btn--ghost btn--sm" aria-label="Next page">Next →</a></li>
                }
            </ul>
        </nav>
    }
</div>
